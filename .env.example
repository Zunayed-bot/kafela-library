# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/kafela_library?schema=public"

# JWT Secret (min 32 chars, use: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"

# JWT Expiry
JWT_EXPIRES_IN="7d"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Upload Directory
UPLOAD_DIR="./public/uploads"
NEXT_PUBLIC_UPLOAD_URL="/uploads"

# Admin Default Credentials (for first seed)
ADMIN_NAME="Admin"
ADMIN_STUDENT_ID="ADMIN001"
ADMIN_PHONE="01700000000"
ADMIN_PASSWORD="AdminPass123!"

# Default Borrow Duration (days)
DEFAULT_BORROW_DAYS="14"

# Default Max Books Per User
DEFAULT_BORROW_LIMIT="3"

# OTP Expiry (minutes)
OTP_EXPIRY_MINUTES="30"

# Node Environment
NODE_ENV="development"
