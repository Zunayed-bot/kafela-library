generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Roles: ADMIN | USER
// AccountStatus: PENDING | ACTIVE | SUSPENDED | INACTIVE
// BorrowStatus: ACTIVE | RETURNED | OVERDUE
// ReservationStatus: PENDING | FULFILLED | CANCELLED | EXPIRED
// BookStatus: AVAILABLE | ALL_ISSUED | RESERVED | UNAVAILABLE
// MembershipTier: GENERAL | SILVER | GOLDEN | PLATINUM

model User {
  id              String   @id @default(cuid())
  name            String
  studentId       String   @unique
  phone           String   @unique
  email           String?  @unique
  password        String?
  department      String?
  session         String?
  profilePicture  String?
  role            String   @default("USER")
  status          String   @default("PENDING")
  membershipTier  String   @default("GOLDEN")
  borrowLimit     Int      @default(3)
  isActivated     Boolean  @default(false)
  activatedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  borrowings      Borrowing[]
  reservations    Reservation[]
  auditLogs       AuditLog[]  @relation("UserLogs")
  adminActions    AuditLog[]  @relation("AdminLogs")
  resetTokens     PasswordResetToken[]

  @@index([studentId])
  @@index([phone])
  @@index([status])
}

model Book {
  id              String   @id @default(cuid())
  title           String
  titleBangla     String?
  author          String
  authorBangla    String?
  publisher       String?
  publisherBangla String?
  publishedYear   Int?
  isbn            String?  @unique
  category        String
  description     String?
  translator      String?
  translatorBangla String?
  coverImage      String?
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)
  shelfNumber     String?
  price           Float?
  language        String   @default("বাংলা")
  status          String   @default("AVAILABLE")
  addedById       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  borrowings      Borrowing[]
  reservations    Reservation[]

  @@index([title])
  @@index([author])
  @@index([category])
  @@index([status])
}

model Borrowing {
  id              String   @id @default(cuid())
  userId          String
  bookId          String
  issuedDate      DateTime @default(now())
  dueDate         DateTime
  returnedDate    DateTime?
  status          String   @default("ACTIVE")
  renewCount      Int      @default(0)
  maxRenewals     Int      @default(2)
  overdueNotified Boolean  @default(false)
  notes           String?
  issuedById      String?
  returnedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book            Book     @relation(fields: [bookId], references: [id])

  @@index([userId])
  @@index([bookId])
  @@index([status])
  @@index([dueDate])
}

model Reservation {
  id            String   @id @default(cuid())
  userId        String
  bookId        String
  status        String   @default("PENDING")
  queuePosition Int
  requestedAt   DateTime @default(now())
  expiresAt     DateTime?
  fulfilledAt   DateTime?
  cancelledAt   DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book          Book     @relation(fields: [bookId], references: [id])

  @@index([userId])
  @@index([bookId])
  @@index([status])
}

model PasswordResetToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  used        Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  createdById String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String?
  userId      String?
  adminId     String?
  details     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User?    @relation("UserLogs", fields: [userId], references: [id])
  admin       User?    @relation("AdminLogs", fields: [adminId], references: [id])

  @@index([action])
  @@index([entity])
  @@index([userId])
  @@index([createdAt])
}

model SystemSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Leadership {
  id          String   @id @default(cuid())
  name        String
  role        String
  description String?
  photo       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  nameEn    String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([order])
}

model ProgramEvent {
  id          String         @id @default(cuid())
  title       String
  description String?
  colorClass  String         @default("bg-emerald-500")
  order       Int            @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  videos      ProgramVideo[]

  @@index([order])
}

model ProgramVideo {
  id          String       @id @default(cuid())
  programId   String
  title       String?
  thumbnail   String?
  videoUrl    String
  order       Int          @default(0)
  createdAt   DateTime     @default(now())

  program     ProgramEvent @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@index([order])
}
